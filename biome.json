{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "plugins": ["./grit/neverthrow-result-consumed.grit"],
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "includes": ["**", "!!**/.turbo", "!!**/dist"] },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "all",
      "complexity": { "noExcessiveCognitiveComplexity": "off" },
      "correctness": { "noUnresolvedImports": "off" },
      "security": { "noSecrets": "off" },
      "style": {
        "noDefaultExport": "off",
        "noJsxLiterals": "off",
        "noTernary": "off"
      },
      "suspicious": { "noReactSpecificProps": "off" },
      "nursery": {
        "recommended": true,
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": { "functions": ["cn", "cva"] }
        }
      }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always" },
    "globals": ["exports", "location"]
  },
  "css": {
    "parser": { "tailwindDirectives": true }
  },
  "overrides": [
    {
      "includes": ["**/*.{jsx,tsx}"],
      "linter": {
        "rules": {
          "correctness": { "useExhaustiveDependencies": "warn" },
          "performance": { "noNamespaceImport": "off" },
          "security": { "noBlankTarget": "off" },
          "suspicious": { "noUnknownAttribute": "off" }
        }
      }
    },
    {
      "includes": ["**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts"],
      "linter": {
        "rules": {
          "correctness": {
            "noConstAssign": "off",
            "noGlobalObjectCalls": "off",
            "noInvalidBuiltinInstantiation": "off",
            "noInvalidConstructorSuper": "off",
            "noSetterReturn": "off",
            "noUndeclaredVariables": "off",
            "noUnreachable": "off",
            "noUnreachableSuper": "off"
          },
          "suspicious": {
            "noClassAssign": "off",
            "noDuplicateClassMembers": "off",
            "noDuplicateObjectKeys": "off",
            "noDuplicateParameters": "off",
            "noFunctionAssign": "off",
            "noImportAssign": "off",
            "noRedeclare": "off",
            "noUnsafeNegation": "off",
            "useGetterReturn": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on", "recommended": true } }
  }
}
