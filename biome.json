{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "includes": ["**", "!!**/.turbo", "!!**/dist"] },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "all",
      "performance": {
        "recommended": true
      },
      "complexity": { "recommended": true },
      "correctness": { "recommended": true },
      "security": { "recommended": true },
      "style": { "recommended": true },
      "suspicious": { "recommended": true },
      "nursery": {
        "recommended": true,
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": { "functions": ["cn", "cva"] }
        }
      },
      "a11y": {
        "recommended": true
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "indentStyle": "space",
      "arrowParentheses": "always",
      "lineWidth": 100,
      "enabled": true,
      "indentWidth": 2
    }
  },
  "css": {
    "parser": { "tailwindDirectives": true }
  },
  "overrides": [],
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on", "recommended": true } }
  }
}
